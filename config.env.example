# Copy this file to config.env and edit it for your machine.
# This file is Bash syntax because it supports arrays.

# -------------------------
# Model
# -------------------------
MODEL_REPO="Qwen/Qwen3-0.6B-Base"
MODEL_REVISION="main"               # Use an exact HF commit hash for strict reproducibility.
MODEL_NAME="Qwen3-0.6B"
OUTTYPE="bf16"

# Quantizations used in this experiment.
QUANTS=(
  Q8_0
  Q4_K_M
  Q2_K
  Q1_0
  IQ3_S
  IQ3_M
  IQ4_NL
  IQ4_XS
)

# Continue if one quant type is unsupported by the installed llama.cpp version.
STRICT_QUANTIZATION="false"

# Optional importance matrix. Leave blank for normal quantization.
IMATRIX_FILE=""

# -------------------------
# llama.cpp
# -------------------------
LLAMA_CPP_REPO="https://github.com/ggml-org/llama.cpp.git"
LLAMA_CPP_REF="master"              # Replace with an exact commit after your first successful run.
BUILD_BACKEND="cpu"                 # cpu or cuda
BUILD_JOBS="0"                      # 0 = use all logical CPU cores

# -------------------------
# Benchmarking
# -------------------------
THREADS="10"
GPU_LAYERS="0"                      # 0 forces CPU; use 99 for GPU offload testing.
PROMPT_TOKENS="512"
GEN_TOKENS="128"
BENCH_REPETITIONS="5"

PPL_CONTEXT="4096"
PPL_CHUNKS="0"                      # 0 = entire corpus. Use 10 for a quick test.

GEN_MAX_TOKENS="128"
GEN_SEED="42"
GEN_TEMPERATURE="0"

# -------------------------
# Hugging Face upload
# -------------------------
HF_REPO_ID="YOUR_USERNAME/Qwen3-0.6B-GGUF"
HF_PRIVATE="false"
HF_REVISION="main"
