# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local machine config (created from config.env.example on first run)
config.env

# Built / cloned tooling
tools/

# Hugging Face upload staging folder (regenerated by script 12)
hf_upload/

# Model files: large downloaded/generated artifacts. Publish GGUFs on
# Hugging Face, not Git (see README). Only the folder READMEs stay tracked.
/models/*
!/models/README.md
!/models/gguf
/models/gguf/*
!/models/gguf/README.md
