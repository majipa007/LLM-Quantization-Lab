# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.venv/

# ---------------------------------------------------------------------------
# Local config / environment files
# The tracked template is config.env.example; real *.env files are per-machine.
# ---------------------------------------------------------------------------
*.env
!*.env.example

# ---------------------------------------------------------------------------
# Tooling cloned/built by the pipeline (regenerated by scripts/01)
# ---------------------------------------------------------------------------
tools/

# ---------------------------------------------------------------------------
# Model files: large downloaded/generated artifacts.
# Publish GGUFs on Hugging Face, not Git. Only folder READMEs stay tracked.
# ---------------------------------------------------------------------------
models/*
!models/README.md
!models/gguf/
models/gguf/*
!models/gguf/README.md

# ---------------------------------------------------------------------------
# Datasets downloaded by the pipeline (scripts/07). Keep prompts + README.
# ---------------------------------------------------------------------------
data/*
!data/README.md
!data/prompts.txt

# ---------------------------------------------------------------------------
# Generated results (regenerated by the benchmarking stages). Keep the README.
# ---------------------------------------------------------------------------
results/*
!results/README.md

# ---------------------------------------------------------------------------
# Hugging Face upload staging (regenerated by scripts/12)
# ---------------------------------------------------------------------------
hf_upload/

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
